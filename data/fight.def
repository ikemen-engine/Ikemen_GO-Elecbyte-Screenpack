; Definition of fight screen

; Motif: IKEMEN1
; Optimal resolution: 1280x720
; Requires: IKEMEN GO 1.0 (Ikemen nightly)

; Notes about fonts:
;   - fonts can be specified in the [Files] section (no limit to how many),
;   - fonts indexed here do not refer to the ones in system.def
;   - fonts are search in directories in the following order:
;     1. system directory
;     2. mugen program directory (not recommended to keep custom fonts here)
;     3. data/ (not recommended to keep custom fonts here)
;     4. font/
;
; See the section "How to Customize" at the end of this file.

;-----------------------------------------------------------
; Ikemen feature
[Info]
name = IKEMEN1              ;Name of motif
author = Ohmga Shironeko    ;Motif author name
versiondate = 03,14,2026    ;Version date of motif (MM-DD-YYYY) 
ikemenversion = 1.0         ;Version of I.K.E.M.E.N motif is compatible with (Ikemen nightly)
localcoord = 1280,720 	;Local coordinate space width and height

;-----------------------------------------------------------
;Directories are checked in this order:
;1. current directory fight.def is in
;2. data/
;3. your MUGEN directory
;eg. If you write "spr = system.sff", and this system.def file
;    is in ~/ikemen/data/mymotif/, then Ikemen will first look
;    for ~/ikemen/data/mymotif/system.sff. If it does not find
;    it there, it looks for ~/ikemen/data/system.sff (the default).
;    Finally, if that is not found, it will look for
;    ~/ikemen/system.sff.

[Files]
sff = fight.sff
snd = fight.snd
font1 = Menu2.def
font2 = Timer.def
font3 = Menu2Small.def
font4 = PowerbarNum.def
font5 = Action.def
font6 = ComboCounter.def
font7 = HitNum.def
font8 = Pixel.def
font9 = Round.def
fightfx.sff = fightfx.sff ;Legacy Mugen common effects
fightfx.air = fightfx.air ;Legacy Mugen common effects
common.snd = common.snd   ;Legacy Mugen common effects
;fx1 =                    ;Extra common effects .def file

;-----------------------------------------------------------
[FightFx]
scale = 4

;-----------------------------------------------------------
[Lifebar]
;Player 1
p1.pos    = 595,40
p1.bg0.spr = 10,0
